    "md":  { "value": "600px",  "type": "dimension", "description": "Large phones / small tablets — near site's 640px mobile breakpoint" },
    "lg":  { "value": "900px",  "type": "dimension", "description": "Tablets / small laptops — layout collapses at 960px" },
    "xl":  { "value": "1200px", "type": "dimension", "description": "Desktops — container max-width" },
    "2xl": { "value": "1440px", "type": "dimension", "description": "Wide desktops — grid max-width" }
