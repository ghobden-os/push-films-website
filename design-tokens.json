    "gutter":    { "value": "24px",                          "type": "dimension", "description": "Gap between columns" },
    "margin":    { "value": "clamp(24px, 5vw, 80px)",        "type": "dimension", "description": "Outer page margin — same as --pad" },
    "maxWidth":  { "value": "1440px",                        "type": "dimension", "description": "Maximum content width" },
    "container": { "value": "1200px",                        "type": "dimension", "description": "Inner container max-width" }
