    },
    "glow-gold": {
      "value": "0 0 24px rgba(196,164,107,0.3)",
      "type": "shadow",
      "description": "Gold glow — accent focus or highlight"
    }
  },

  "motion": {
    "duration": {
      "fast":   { "value": "150ms",  "type": "duration", "description": "Fast micro-interactions — hover colour, opacity" },
      "base":   { "value": "250ms",  "type": "duration", "description": "Base transitions — all 0.25s" },
      "slow":   { "value": "400ms",  "type": "duration", "description": "Slower transitions — nav bg, accordion" },
      "hero":   { "value": "1400ms", "type": "duration", "description": "Hero entrance animations" },
      "reveal": { "value": "1800ms", "type": "duration", "description": "Section fade-in reveal animations" }
    },
    "easing": {
      "standard":    { "value": "cubic-bezier(0.4, 0, 0.2, 1)",    "type": "cubicBezier", "description": "Standard ease — most transitions" },
      "decelerate":  { "value": "cubic-bezier(0, 0, 0.2, 1)",      "type": "cubicBezier", "description": "Elements entering the screen" },
      "accelerate":  { "value": "cubic-bezier(0.4, 0, 1, 1)",      "type": "cubicBezier", "description": "Elements leaving the screen" },
      "spring":      { "value": "cubic-bezier(0.16, 1, 0.3, 1)",   "type": "cubicBezier", "description": "Spring — section reveal, historic fade-in" },
      "linear":      { "value": "linear",                           "type": "cubicBezier", "description": "Linear — progress bars, typewriter" }
    }
  },

  "breakpoint": {
